{
  "metadata": {
    "version": "1.0.0",
    "last_updated": "2025-01-14",
    "description": "Flag definitions for NIRSpec visual inspection and quality assessment"
  },
  "redshift_quality": {
    "0": {
      "value": 0,
      "label": "Not Inspected",
      "short": "None",
      "icon": "\u26aa",
      "color": "#e0e0e0",
      "description": "Not yet visually inspected"
    },
    "1": {
      "value": 1,
      "label": "Impossible",
      "short": "Bad",
      "icon": "\ud83d\udd34",
      "color": "#dc3545",
      "description": "Impossible to determine redshift from available data"
    },
    "2": {
      "value": 2,
      "label": "Tentative",
      "short": "Tent.",
      "icon": "\ud83d\udfe0",
      "color": "#ffc107",
      "description": "Redshift uncertain but plausible (~50% confidence)"
    },
    "3": {
      "value": 3,
      "label": "Probable",
      "short": "Prob.",
      "icon": "\ud83d\udfe1",
      "color": "#ff9800",
      "description": "Redshift likely correct (~80% confidence)"
    },
    "4": {
      "value": 4,
      "label": "Secure",
      "short": "Secure",
      "icon": "\ud83d\udfe2",
      "color": "#28a745",
      "description": "Redshift definitely correct (>95% confidence)"
    }
  },
  "flag_categories": {
    "spectral_features": {
      "description": "Spectral features used for redshift determination",
      "type": "multi_select",
      "storage": "bitmask",
      "flags": {
        "continuum_break": {
          "bit": 0,
          "label": "Continuum Shape",
          "short": "Cont",
          "icon": "\ud83d\udcca",
          "color": "#e8f5e9",
          "description": "Redshift constrained by the overall continuum shape",
          "value": 1
        },
        "lyman_break": {
          "bit": 1,
          "label": "Lyman Break",
          "short": "LB",
          "icon": "\ud83d\udca7",
          "color": "#e3f2fd",
          "description": "Clear Lyman break",
          "value": 2
        },
        "balmer_break": {
          "bit": 2,
          "value": 4,
          "label": "Balmer Break",
          "short": "BB",
          "icon": "\ud83d\udcc8",
          "color": "#f3e5f5",
          "description": "Clear Balmer break"
        },
        "absorption_features": {
          "bit": 3,
          "value": 8,
          "label": "Absorption Features",
          "short": "ABS",
          "icon": "\u3030\ufe0f",
          "color": "#f1f8e9",
          "description": "Absorption lines/features identified"
        },
        "single_emission": {
          "bit": 4,
          "value": 16,
          "label": "Single Emission Line",
          "short": "1EM",
          "icon": "\u261d\ufe0f",
          "color": "#fff3e0",
          "description": "Single emission line"
        },
        "multi_emission": {
          "bit": 5,
          "value": 32,
          "label": "Multiple Emission Lines",
          "short": "MEM",
          "icon": "\u270c\ufe0f",
          "color": "#ffebee",
          "description": "Multiple emission lines"
        }
      }
    },
    "object_flags": {
      "description": "Object properties and classifications",
      "type": "multi_select",
      "storage": "bitmask",
      "flags": {
        "LRD": {
          "bit": 0,
          "value": 1,
          "label": "Little Red Dot",
          "short": "LRD",
          "icon": "\ud83d\udd34",
          "color": "#ffcccb",
          "description": "Little red dot"
        },
        "broad_line": {
          "bit": 1,
          "value": 2,
          "label": "Broad Line",
          "short": "BL",
          "icon": "\ud83c\udf0b",
          "color": "#c8e6c9",
          "description": "Broad emission line"
        },
        "lya_emitter": {
          "bit": 2,
          "value": 4,
          "label": "Ly\u03b1 Emitter",
          "short": "LAE",
          "icon": "\u2728",
          "color": "#bbdefb",
          "description": "Strong Lyman-alpha emission"
        },
        "balmer_break_galaxy": {
          "bit": 3,
          "value": 8,
          "label": "Balmer Break Galaxy",
          "short": "BBG",
          "icon": "\ud83c\udf0c",
          "color": "#e1bee7",
          "description": "Strong Balmer break indicating evolved stellar population"
        },
        "oiii_emitter": {
          "bit": 4,
          "value": 16,
          "label": "[OIII] Emitter",
          "short": "O3E",
          "icon": "\u26a1\ufe0f",
          "color": "#fff59d",
          "description": "Strong [OIII]4959,5007 emitter"
        },
        "ha_emitter": {
          "bit": 5,
          "value": 32,
          "label": "H\u03b1 Emitter",
          "short": "HAE",
          "icon": "\ud83d\udd25",
          "color": "#f398adff",
          "description": "Strong H-alpha emitter"
        },
        "passive": {
          "bit": 6,
          "value": 64,
          "label": "Quiescent",
          "short": "QG",
          "icon": "\ud83d\ude34",
          "color": "#d7ccc8",
          "description": "Quiescent galaxy with little star formation"
        },
        "dusty": {
          "bit": 7,
          "value": 128,
          "label": "Dusty",
          "short": "DUST",
          "icon": "\ud83c\udf2b\ufe0f",
          "color": "#ffccbc",
          "description": "Significant dust attenuation"
        },
        "star": {
          "bit": 8,
          "value": 256,
          "label": "Star",
          "short": "STAR",
          "icon": "\u2b50",
          "color": "#ffeb3b",
          "description": "Stellar spectrum"
        }
      }
    },
    "dq_flags": {
      "description": "Data quality issues affecting the spectrum",
      "type": "multi_select",
      "storage": "bitmask",
      "flags": {
        "chip_gap": {
          "bit": 0,
          "value": 1,
          "label": "Chip Gap",
          "short": "GAP",
          "icon": "\u26a0\ufe0f",
          "color": "#fff9c4",
          "description": "Spectrum affected by detector chip gap"
        },
        "contamination": {
          "bit": 1,
          "value": 2,
          "label": "Contamination",
          "short": "CONTAM",
          "icon": "\ud83d\udeab",
          "color": "#ffe0b2",
          "description": "Contamination from nearby source or open shutter"
        },
        "stuck_shutter": {
          "bit": 2,
          "value": 4,
          "label": "Stuck Closed Shutter",
          "short": "CLOSED",
          "icon": "\ud83d\udd12",
          "color": "#ffcdd2",
          "description": "Possible stuck closed shutter"
        },
        "multiple_sources": {
          "bit": 3,
          "value": 8,
          "label": "Multiple Sources",
          "short": "MULT",
          "icon": "\ud83d\udc65",
          "color": "#b3e5fc",
          "description": "Multiple sources in slitlet"
        },
        "no_detection": {
          "bit": 4,
          "value": 16,
          "label": "No Detection",
          "short": "NONE",
          "icon": "\u274c",
          "color": "#e0e0e0",
          "description": "No source detected in spectrum"
        },
        "low_snr": {
          "bit": 5,
          "value": 32,
          "label": "Low S/N",
          "short": "SNR",
          "icon": "\ud83d\udcc9",
          "color": "#ffecb3",
          "description": "Low signal-to-noise ratio"
        },
        "spectral_overlap": {
          "bit": 6,
          "value": 64,
          "label": "Spectral Overlap",
          "short": "OVER",
          "icon": "\ud83d\udd17",
          "color": "#f3e5f5",
          "description": "Spectral overlap in grating spectrum"
        },
        "prism_corrupted": {
          "bit": 7,
          "value": 128,
          "label": "PRISM Corrupted",
          "short": "P-BAD",
          "icon": "\ud83c\udf08\u274c",
          "color": "#ffccbc",
          "description": "PRISM data corrupted or unusable"
        },
        "grating_corrupted": {
          "bit": 8,
          "value": 256,
          "label": "Grating Corrupted",
          "short": "G-BAD",
          "icon": "\ud83d\udd34\u274c",
          "color": "#ffcdd2",
          "description": "Grating data corrupted or unusable"
        }
      }
    }
  },
  "bitmask_categories": [
    "spectral_features",
    "object_flags",
    "dq_flags"
  ],
  "migration": {
    "description": "Mapping for migrating from old string-based system",
    "redshift_quality_map": {
      "-1": 1,
      "0": 0,
      "1": 2,
      "2": 4
    },
    "object_flags_map": {
      "LRD": "LRD",
      "Broad line": "broad_line",
      "Lya": "lya_emitter",
      "Balmer break": "balmer_break_galaxy"
    },
    "dq_flags_map": {
      "Chip gap / detector gap": "chip_gap",
      "Contamination from open shutter": "contamination",
      "Possible stuck closed shutter": "stuck_shutter",
      "Multiple sources in slitlet": "multiple_sources",
      "No detection": "no_detection",
      "Low S/N": "low_snr",
      "Spectral overlap in grating": "spectral_overlap"
    }
  }
}