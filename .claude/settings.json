{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "Bash(ls:*)",
      "Bash(mv:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(du:*)",
      "Bash(wc:*)",
      "Bash(export:*)",
      "Bash(npm install:*)",
      "Bash(npm run build:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(python:*)",
      "Bash(pytest:*)",
      "Bash(conda run:*)",
      "Bash(conda env:*)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(pip install:*)"
    ],
    "ask": []
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "supabase"
  ],
  "spinnerTipsEnabled": false
}
